# PlateMate Backend - Environment Configuration
# Copy this file and update values before starting services.
# Never commit real credentials to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# Password used by all five PostgreSQL instances
DB_PASSWORD=change_me_strong_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters long in production
JWT_SECRET=change_me_random_secret_min_32_chars_long

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
